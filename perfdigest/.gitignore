# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# Virtual environments (recreated via `uv sync` — never commit)
.venv/
venv/
workshop-env/

# uv
# uv.lock IS committed (reproducible installs). Do not ignore it.

# Profiler reports are large binaries and regenerable (see tests/conftest.py for
# the ncu command) — never commit them, even under tests/fixtures/. The fixtures
# dir is kept in git via its .gitkeep; the reports themselves stay local.
*.ncu-rep
*.csv
!tests/fixtures/.gitkeep

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# Sandbox scratch leftovers (safe to delete on Windows)
_gittest/
_t1
_t2
.write_test
